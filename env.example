# Copier en .env à la racine : cp env.example .env
# Docker Compose charge automatiquement .env (fichier ignoré par git)
#
# --- Météo (Feature 1 + 2) — TOUT EST OPTIONNEL ---
#
# 1) Tomorrow.io (optionnel) : https://www.tomorrow.io/
TOMORROW_API_KEY=

# 2) Sans clé : Open-Meteo est utilisé automatiquement (gratuit, sans inscription)
#
# 3) Sans réseau : alertes météo simulées via webhook local :
#    ./test-weather.sh
#
# URL publique du webhook Tomorrow.io (si vous utilisez leur service d'alertes)
TOMORROW_WEBHOOK_URL=http://host.docker.internal:8081/api/weather/webhook
WEATHER_WEBHOOK_SECRET=replace-with-a-long-random-secret
